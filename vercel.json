{
  "version": 2,
  "buildCommand": "npm run vercel-build && npx esbuild server/app.ts --bundle --platform=node --format=cjs --packages=external --outfile=api/_bundle.cjs",
  "outputDirectory": "dist/public",
  "functions": {
    "api/index.ts": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index" },
    { "source": "/manifest.json", "destination": "/api/index" },
    { "source": "/nurgay/:path*", "destination": "/api/index" },
    { "source": "/fxggxt/:path*", "destination": "/api/index" },
    { "source": "/justthegays/:path*", "destination": "/api/index" },
    { "source": "/besthdgayporn/:path*", "destination": "/api/index" },
    { "source": "/boyfriendtv/:path*", "destination": "/api/index" },
    { "source": "/gaycock4u/:path*", "destination": "/api/index" },
    { "source": "/gaystream/:path*", "destination": "/api/index" },
    { "source": "/catalog/:path*", "destination": "/api/index" },
    { "source": "/meta/:path*", "destination": "/api/index" },
    { "source": "/stream/:path*", "destination": "/api/index" },
    { "source": "/proxy/:path*", "destination": "/api/index" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/manifest.json",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "*" }
      ]
    },
    {
      "source": "/:provider(nurgay|fxggxt|justthegays|besthdgayporn|boyfriendtv|gaycock4u|gaystream)/manifest.json",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "*" }
      ]
    },
    {
      "source": "/catalog/:path*",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    },
    {
      "source": "/meta/:path*",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    },
    {
      "source": "/stream/:path*",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    }
  ]
}
